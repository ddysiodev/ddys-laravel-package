{
  "name": "ddysiodev/ddys-laravel-package",
  "description": "Official Laravel package for the DDYS API with pages, Blade components, shortcodes, proxy, caching, diagnostics, and request form.",
  "type": "library",
  "license": "MIT",
  "homepage": "https://ddys.io",
  "keywords": [
    "ddys",
    "laravel",
    "movie",
    "video",
    "blade",
    "package"
  ],
  "authors": [
    {
      "name": "DDYS",
      "homepage": "https://ddys.io"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/validation": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/view": "^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
    "pestphp/pest": "^2.0|^3.0|^4.0",
    "phpunit/phpunit": "^10.0|^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "Ddys\\Laravel\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Ddys\\Laravel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Ddys\\Laravel\\DdysServiceProvider"
      ],
      "aliases": {
        "Ddys": "Ddys\\Laravel\\Facades\\Ddys"
      }
    }
  },
  "scripts": {
    "test:structure": "node tools/check.mjs",
    "test": "node tools/check.mjs"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
